# FinMentor AI — Environment Variables Template
# Copy to .env and fill in your values
# cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Environment ───────────────────────────────────────────────────────────────
FINMENTOR_ENV=development          # development | staging | production

# ── LLM ───────────────────────────────────────────────────────────────────────
FINMENTOR__LLM__MODEL=claude-sonnet-4-20250514
FINMENTOR__LLM__MAX_TOKENS=4096
FINMENTOR__LLM__TEMPERATURE=0.2

# ── RL Model ──────────────────────────────────────────────────────────────────
FINMENTOR__RL_MODEL__BACKEND=mock              # mock | sb3
# FINMENTOR__RL_MODEL__MODEL_PATH=saved_models/finmentor_ppo.zip
# FINMENTOR__RL_MODEL__ALGORITHM=PPO
# FINMENTOR__RL_MODEL__DEVICE=cpu

# ── Memory ────────────────────────────────────────────────────────────────────
FINMENTOR__AGENT__MEMORY_BACKEND=json          # json | redis | memory
# REDIS_URL=redis://localhost:6379/0

# ── Agent ─────────────────────────────────────────────────────────────────────
FINMENTOR__AGENT__MAX_PLANNING_STEPS=8
FINMENTOR__AGENT__ENABLE_MEMORY=true
FINMENTOR__AGENT__PREDICTION_TOLERANCE_PCT=10.0

# ── Server ────────────────────────────────────────────────────────────────────
FINMENTOR__SERVER__PORT=8080
FINMENTOR__SERVER__WORKERS=4

# ── Logging ───────────────────────────────────────────────────────────────────
FINMENTOR__OBSERVABILITY__LOG_LEVEL=INFO
FINMENTOR__OBSERVABILITY__ENABLE_JSON_LOGS=false   # true in production
